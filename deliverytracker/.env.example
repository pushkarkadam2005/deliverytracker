# =============================================================================
# DeliveryTracker — Environment Variables
#
# USAGE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in .env
#   3. .env is listed in .gitignore — never commit it
#
# docker-compose.yml reads all variables from .env automatically.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DT_DB_NAME=delivery_tracker
DT_DB_USERNAME=deliverytracker
DT_DB_PASSWORD=deliverytracker_pass
DT_DB_PORT=5435

# ── Spring Boot server ────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── JWT Security ──────────────────────────────────────────────────────────────
# Must be at least 256 bits (32 characters) for HS256 signing.
JWT_SECRET_KEY=jdhaskihkasajnc,jsdncvkusfliajdlkamaidhaidkjncjkasndkmdioiwejdijwdfikanankalkadk
JWT_EXPIRATION=86400000

# ── Spring Mail (SMTP) ────────────────────────────────────────────────────────
# Leave blank to disable email sending in development.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=default
